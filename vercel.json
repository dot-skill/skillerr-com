{
  "buildCommand": "npm run build",
  "outputDirectory": "docs/.vitepress/dist",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "skillerr.com" }],
      "destination": "https://docs.skillerr.com/:path*",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.skillerr.com" }],
      "destination": "https://docs.skillerr.com/:path*",
      "permanent": false
    },
    {
      "source": "/docs/:path*",
      "destination": "/:path*",
      "permanent": true
    }
  ],
  "functions": {
    "api/verify.js": {
      "includeFiles": "docs/public/trust/trust-store.json"
    }
  }
}
